{
    "framework": "nextjs",
    "buildCommand": "prisma generate && prisma db push && next build",
    "installCommand": "npm install",
    "crons": [
        {
            "path": "/api/cron/snapshot",
            "schedule": "30 18 * * *"
        }
    ],
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                }
            ]
        }
    ]
}